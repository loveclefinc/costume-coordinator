    "@tanstack/react-query": "^5.60.0",
    "@trpc/client": "11.7.2",
    "@trpc/react-query": "11.7.2",
    "@trpc/server": "11.7.2",
    "axios": "^1.12.0",
    "cookie": "^1.0.2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.5",
    "express": "^4.21.2",
    "jose": "6.1.0",
    "jsqr": "^1.4.0",
    "mysql2": "^3.15.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^6.20.0",
    "superjson": "^1.13.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.8.1",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
