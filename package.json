{
  "name": "costume-coordinator",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
