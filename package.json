    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.4",
    "esbuild": "^0.25.0",
    "eslint": "^9.25.0",
    "prettier": "^3.6.2",
    "tsx": "^4.19.1",
    "typescript": "~5.9.2",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.17.0",
    "vitest": "^2.1.4"
